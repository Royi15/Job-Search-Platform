# Copy to .env and fill in. .env is gitignored — never commit secrets.

# --- Core ---
DEBUG=false
DATABASE_URL=postgresql+asyncpg://jobsearch:CHANGE_ME@localhost:5432/jobsearch
REDIS_URL=redis://localhost:6379/0
# Upstash: rediss://default:<password>@<host>.upstash.io:6379

# --- Auth ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=CHANGE_ME
ACCESS_TOKEN_MINUTES=30
REFRESH_TOKEN_DAYS=14

# --- LLM (Gemini) — provided by the platform owner, not per-user ---
LLM_API_KEY=CHANGE_ME
LLM_MODEL=gemini-3.1-flash-lite

# --- Telegram bot (create via @BotFather) ---
TELEGRAM_BOT_TOKEN=CHANGE_ME
TELEGRAM_BOT_USERNAME=YourJobAlertsBot
# Random string; also passed to setWebhook so we can verify inbound updates:
TELEGRAM_WEBHOOK_SECRET=CHANGE_ME

# --- Bright Data (LinkedIn student-jobs discovery) ---
# Empty key = the worker falls back to the free Remotive API (dev mode).
BRIGHTDATA_API_KEY=CHANGE_ME
BRIGHTDATA_DATASET_ID=gd_lpfll7v5hcqtkxl6l
BRIGHTDATA_KEYWORD=student
BRIGHTDATA_LOCATION=israel
BRIGHTDATA_COUNTRY=IL
BRIGHTDATA_TIME_RANGE=Past 24 hours

# --- Discord community channel ---
# Server Settings -> Integrations -> Webhooks -> New Webhook -> Copy URL.
# Every newly found student job is broadcast here (in addition to personal
# Telegram alerts). Leave empty to disable.
DISCORD_WEBHOOK_URL=

# --- Misc ---
UPLOAD_DIR=./uploads
CORS_ORIGINS=["http://localhost:5173","https://your-app.vercel.app"]
